---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" description="This page could not be found.">
  <section class="section">
    <div class="wrap prose center">
      <p class="eyebrow">404</p>
      <h1>Nothing here</h1>
      <p class="muted">This page could not be found. It may have moved, or never existed.</p>
      <p style="margin-top:1.5rem"><a class="btn ghost" href="/">Back to the press</a></p>
    </div>
  </section>
</Base>
