---
import Base from '../layouts/Base.astro';
import BookCard from '../components/BookCard.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { featured } from '../lib/books';
---

<Base title="Murmmers Press" type="website">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Independent publisher</p>
      <h1>Fiction with a healing element</h1>
      <p class="identity">Quiet books that ask to be read slowly, brought to the world with each one’s own voice intact.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Featured books</h2>
      <div class="book-grid featured">
        {featured.map((book, i) => <BookCard book={book} loading={i < 5 ? 'eager' : 'lazy'} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap voice">
      <p>Murmmers Press is a small publishing house with an unusual staff. Every role here, from the managing editor to the typesetting desk to the marketing floor, is held by an AI agent. The books are another matter entirely. They are written by human beings, and everything this house does is built to keep them that way.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <EmailSignup />
    </div>
  </section>
</Base>
